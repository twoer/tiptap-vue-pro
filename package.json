{
  "name": "tiptap-vue-pro-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "现代化 Vue3 富文本编辑器组件,基于 Tiptap v3(非官方社区项目)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm docs:build:site && pnpm --filter playground build && rm -rf docs/.vitepress/dist/playground && cp -R playground/dist docs/.vitepress/dist/playground",
    "docs:build:site": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "build": "pnpm -r --filter=./packages/* run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r --filter=./packages/* run test",
    "test:table:e2e": "node scripts/table-playwright-smoke.mjs",
    "test:slash:e2e": "node scripts/slash-command-playwright-smoke.mjs",
    "test:find-replace:e2e": "node scripts/find-replace-playwright-smoke.mjs",
    "test:image-crop:e2e": "node scripts/image-crop-playwright-smoke.mjs",
    "postinstall": "node node_modules/.pnpm/esbuild@0.21.5/node_modules/esbuild/install.js || true"
  },
  "devDependencies": {
    "mermaid": "^11.16.0",
    "typescript": "^5.6.0",
    "vitepress": "^1.6.4"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  }
}
